generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 部門
model Department {
  id        Int       @id @default(autoincrement())
  code      String    @unique @db.VarChar(32)
  name      String    @db.VarChar(64)
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  projects Project[]
  users    User[]

  @@map("departments")
}

// 使用者
model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique @db.VarChar(128)
  displayName   String    @db.VarChar(64) @map("display_name")
  title         String?   @db.VarChar(64)  // 職稱，例：首席財務工程師
  role          String    @default("editor") @db.VarChar(16) // admin / editor / viewer
  departmentId  Int?      @map("department_id")
  department    Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  avatarUrl     String?   @db.VarChar(255) @map("avatar_url")
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  projectsCreated   Project[]      @relation("ProjectCreatedBy")
  projectsUpdated   Project[]      @relation("ProjectUpdatedBy")
  ownedProjects     ProjectOwner[]
  assignedSubtasks  Subtask[]      @relation("SubtaskAssignee")
  createdSubtasks   Subtask[]      @relation("SubtaskCreatedBy")

  @@map("users")
}

// 開發項目
model Project {
  id              Int       @id @default(autoincrement())
  code            String?   @unique @db.VarChar(64)
  departmentId    Int       @map("department_id")
  department      Department @relation(fields: [departmentId], references: [id])
  name            String    @db.VarChar(255)
  status          String    @default("planning") @db.VarChar(32) // planning / in_progress / done / archived
  tag             String?   @db.VarChar(64)
  frequency       String?   @db.VarChar(64)

  aiDirection     String?   @db.Text @map("ai_direction")
  expectedOutput  String?   @db.Text @map("expected_output")
  logic           String?   @db.Text

  plannedStart    DateTime? @db.Date @map("planned_start")
  plannedEnd      DateTime? @db.Date @map("planned_end")
  actualStart     DateTime? @db.Date @map("actual_start")
  actualEnd       DateTime? @db.Date @map("actual_end")

  durationDays    Int?      @map("duration_days") // 工作天數，null = 使用全域預設
  manualProgress  Int?      @map("manual_progress") // 0-100; null = auto
  notes           String?   @db.Text

  sortOrder       Int       @default(0) @map("sort_order")
  isCustom        Boolean   @default(false) @map("is_custom")
  isArchived      Boolean   @default(false) @map("is_archived")

  createdById     Int?      @map("created_by")
  createdBy       User?     @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedById     Int?      @map("updated_by")
  updatedBy       User?     @relation("ProjectUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedAt       DateTime  @updatedAt @map("updated_at")

  owners          ProjectOwner[]
  subtasks        Subtask[]
  statusHistory   StatusHistory[]

  @@index([departmentId, status])
  @@index([status])
  @@index([plannedEnd])
  @@index([tag])
  @@map("projects")
}

// 多對多：專案負責人
model ProjectOwner {
  projectId     Int      @map("project_id")
  userId        Int      @map("user_id")
  roleInProject String   @default("owner") @db.VarChar(32) @map("role_in_project")
  assignedAt    DateTime @default(now()) @map("assigned_at")

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
  @@map("project_owners")
}

// 細項任務
model Subtask {
  id            Int       @id @default(autoincrement())
  projectId     Int       @map("project_id")
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title         String    @db.VarChar(255)
  description   String?   @db.Text
  isDone        Boolean   @default(false) @map("is_done")
  dueDate       DateTime? @db.Date @map("due_date")
  assigneeId    Int?      @map("assignee_id")
  assignee      User?     @relation("SubtaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  sortOrder     Int       @default(0) @map("sort_order")
  completedAt   DateTime? @map("completed_at")
  createdById   Int?      @map("created_by")
  createdBy     User?     @relation("SubtaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([assigneeId])
  @@index([dueDate])
  @@map("subtasks")
}

// 狀態變更記錄
model StatusHistory {
  id         Int      @id @default(autoincrement())
  projectId  Int      @map("project_id")
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromStatus String?  @db.VarChar(32) @map("from_status")
  toStatus   String   @db.VarChar(32) @map("to_status")
  changedBy  Int?     @map("changed_by")
  changedAt  DateTime @default(now()) @map("changed_at")
  note       String?  @db.VarChar(255)

  @@index([projectId, changedAt])
  @@map("status_history")
}


// 全域設定（key/value 表）
model Setting {
  key       String   @id @db.VarChar(64)
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
